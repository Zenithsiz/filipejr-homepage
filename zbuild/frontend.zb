rule frontend_run {
	exec "trunk" "serve"
		"--config" "homepage-frontend/Trunk.toml";
}

rule frontend_build {
	exec "trunk" "build"
		"--release"
		"--config" "homepage-frontend/Trunk.toml";
}

rule frontend_deploy {
	dep rule frontend_build;

	exec "rsync"
		"--recursive"
		"--compress"
		"--verbose"
		"--delete"
		"homepage-frontend/dist/"
		"{remote}:{remote_www_path}/";

	exec "ssh" remote "chown -R homepage:homepage '{remote_www_path}' && chmod -R 1775 '{remote_www_path}'";
}
